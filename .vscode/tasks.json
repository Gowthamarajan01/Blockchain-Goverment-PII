{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Python Dependencies",
      "type": "shell",
      "command": "${workspaceFolder}/backend/venv/Scripts/pip.exe install -r requirements.txt && ${workspaceFolder}/backend/venv/Scripts/python.exe -m spacy download en_core_web_sm",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Install Frontend Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "Install All Dependencies",
      "dependsOn": [
        "Install Python Dependencies",
        "Install Frontend Dependencies"
      ],
      "problemMatcher": []
    },
    {
      "label": "Run Backend (FastAPI)",
      "type": "shell",
      "command": "${workspaceFolder}/backend/venv/Scripts/python.exe -m backend.main",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run Frontend (Vite)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
